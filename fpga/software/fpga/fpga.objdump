  __asm__ volatile ("break 2" : : "D02"(r2), "D03"(r3) ALT_GMON_DATA );

#else /* !DEBUG_STUB */
  if (r2) {
    ad24:	e0bffe17 	ldw	r2,-8(fp)
    ad28:	1005003a 	cmpeq	r2,r2,zero
    ad2c:	1000021e 	bne	r2,zero,ad38 <alt_sim_halt+0x2c>
    ALT_SIM_FAIL();
