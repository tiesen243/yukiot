	component system is
		port (
			clk_clk                               : in  std_logic                     := 'X';             -- clk
			uart_0_external_connection_rxd        : in  std_logic                     := 'X';             -- rxd
			uart_0_external_connection_txd        : out std_logic;                                        -- txd
			button_external_connection_export     : in  std_logic_vector(31 downto 0) := (others => 'X'); -- export
			lcd_on_external_connection_export     : out std_logic_vector(31 downto 0);                    -- export
			lcd_blon_external_connection_export   : out std_logic_vector(31 downto 0);                    -- export
			lcd_en_external_connection_export     : out std_logic_vector(31 downto 0);                    -- export
			lcd_rw_external_connection_export     : out std_logic_vector(31 downto 0);                    -- export
			lcd_rs_external_connection_export     : out std_logic_vector(31 downto 0);                    -- export
			lcd_d_external_connection_export      : out std_logic_vector(31 downto 0);                    -- export
			buzz_external_connection_export       : out std_logic;                                        -- export
			switch_external_connection_export     : in  std_logic_vector(31 downto 0) := (others => 'X'); -- export
			button_col_external_connection_export : in  std_logic_vector(31 downto 0) := (others => 'X'); -- export
			button_row_external_connection_export : out std_logic_vector(31 downto 0);                    -- export
			hex0_external_connection_export       : out std_logic_vector(31 downto 0);                    -- export
			hex1_external_connection_export       : out std_logic_vector(31 downto 0);                    -- export
			hex2_external_connection_export       : out std_logic_vector(31 downto 0)                     -- export
		);
	end component system;

